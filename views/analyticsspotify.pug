doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Analytics
  link(rel='stylesheet' href='/static/analyticsspotify.css')
.container
  aside.sidebar
    .logo
      img(src='/static/photos/dashboard logo.png' alt='')
      h2 Dashboard
    ul.menu
      li
        a(href='/dashboard')
          img(src='/static/photos/overview icon.png' alt='')
          span  Overview 
      li.active
        a(href='/analyticsgithub')
          img(src='/static/photos/analytics icon.png' alt='')
          span Analytics
      li
        a(href='/goals')
          img(src='/static/photos/goals icon.png' alt='')
          span Goals
      li
        a(href='/integration')
          img(src='/static/photos/integrations icon.png' alt='')
          span Integrations
      li
        a(href='/reports')
          img(src='/static/photos/reports icon.png' alt='')
          span Reports
      li
        a(href='/achievements')
          img(src='/static/photos/achievements icon.png' alt='')
          span Achievements
      li
        a(href='/settingsprofile')
          img(src='/static/photos/settings icon.png' alt='')
          span Settings
  .main-content
    // responsive header
    header.responsive-header
      .header-left
        button.menu-btn(onclick='roggle()')  &#x2630; 
        h2 Dashboard
      .header-right
        .notification-wrapper
          img.notifications-icon(src='/static/photos/notifications icon.jpeg' alt='notification')
          span.badge 3
        img.profile-logo(src='static/photos/profile logo.png' alt='profile photo')
    .content(onclick='moggle()')
      // Header
      header.analytics-header
        div
          h2 Analytics
          p  Deep dive into your productivity 
      .tabs
        button(onclick="window.location.href='/analyticsgithub'") Github
        button(onclick="window.location.href='/analyticscodeforces'") Codeforeces
        button(onclick="window.location.href='/analyticsspotify'"  class="active") Spotify
        button(onclick="window.location.href='/analyticscalender'") Calendar
      section.analytics-cards
        .card
          .left &#x1F3B5;
          .right
            h4 Total Listening Time
            div
              b 18h 42m
            span &uarr; 22% vs last 7 days 
        .card
          .left &#x1F3B5;
          .right
            h4 Songs Played
            div
              b 230
            span &uarr; 15% vs last 7 days 
        .card
          .left &#x1F3B5;
          .right
            h4 Unique Artists
            div
              b 27
            span &uarr; 12% vs last 7 days 
        .card
          .left &#x1F3B5;
          .right
            h4 Avg. Track Duration
            div
              b 3m 40s
            span &darr; 4% vs last 7 days 
      section.top-widgets
        #chart1
        #recentsongs.widget
          p.scroll-hint &larr; Swipe horizontally to view all &rarr;
          .header
            h4  Recently Played 
            a(href='#') View All &gt; 
          table.recentsongs
            thead
              tr
                th Songs
                th Last Played
            tbody
              tr
                td.recent
                  img(src='/static/photos/1st rank icon.jpg' alt='')
                  span  Shape of You anvnadjklvkadgbjka 
                td 3 min ago
              tr
                td.recent
                  img(src='/static/photos/2nd rank icon.jpg' alt='')
                  span  Dil Diyan Gallan 
                td 8 min ago
              tr
                td.recent
                  img(src='/static/photos/3rd rank icon.jpg' alt='')
                  span  Sapphire 
                td 12 min ago
              tr
                td.recent
                  img(src='/static/photos/4th rank icon.jpg' alt='')
                  span  Channa Mereya 
                td 23 min ago
              tr
                td.recent
                  img(src='/static/photos/5th rank icon.jpg' alt='')
                  span  O Maahi 
                td 28 min ago
        #artists.widget
          p.scroll-hint &larr; Swipe horizontally to view all &rarr;
          .header
            h4  Top Artists
            a(href='#') View All &gt;
          table.artists
            thead
              tr
                th #
                th Artists
                th Worldwide Popularity
            tbody
              tr
                td 1
                td.singer
                  img(src='/static/photos/artist logo.jpg' alt='')
                  span  Arijit Singhdfhdgjdg 
                td 90/100
              tr
                td 2
                td.singer
                  img(src='/static/photos/artist logo.jpg' alt='')
                  span Atif Aslam
                td 90/100
              tr
                td 3
                td.singer
                  img(src='/static/photos/artist logo.jpg' alt='')
                  span  Ed Sheeran 
                td 90/100
              tr
                td 4
                td.singer
                  img(src='/static/photos/artist logo.jpg' alt='')
                  span  Rahat F. Ali Khan 
                td 90/100
              tr
                td 5
                td.singer
                  img(src='/static/photos/artist logo.jpg' alt='')
                  span  Shreya Ghosal 
                td 90/100
      section.bottom-widgets
        #tracks.widget
          p.scroll-hint &larr; Swipe horizontally to view all &rarr;
          .header
            h4  Top Tracks 
            a(href='#') View All &gt; 
          table.tracks
            thead
              tr
                th #
                th Track
                th Artists
            tbody
              tr
                td 1
                td.song
                  img(src='/static/photos/album logo.jpg' alt='logo')
                  span Sapphire
                td Ed Sheeran
              tr
                td 2
                td.song
                  img(src='/static/photos/album logo.jpg' alt='logo')
                  span Ik vari aa
                td Arijit singh
              tr
                td 3
                td.song
                  img(src='/static/photos/album logo.jpg' alt='logo')
                  span Besabariyaan
                td Arijit Singh
              tr
                td 4
                td.song
                  img(src='/static/photos/album logo.jpg' alt='logo')
                  span Dil Diyan Gallan
                td Atif Aslam
              tr
                td 5
                td.song
                  img(src='/static/photos/album logo.jpg' alt='logo')
                  span Afreen Afreen
                td Rahat F.Ali khan
        #playlists.widget
          p.scroll-hint &larr; Swipe horizontally to view all &rarr;
          .header
            h4  Top Playlists 
            a(href='#') View All &gt; 
          table.playlists
            thead
              tr
                th #
                th Playlists
                th No. of Songs
            tbody
              tr
                td 1
                td.playlist
                  img(src='/static/photos/playlist icon.png' alt='')
                  span Chill Vibesdshdtrhrs
                td 26
              tr
                td 2
                td.playlist
                  img(src='/static/photos/playlist icon.png' alt='')
                  span Lofi Version
                td 22
              tr
                td 3
                td.playlist
                  img(src='/static/photos/playlist icon.png' alt='')
                  span Road Trip
                td 14
              tr
                td 4
                td.playlist
                  img(src='/static/photos/playlist icon.png' alt='')
                  span Happy Hits
                td 18
              tr
                td 5
                td.playlist
                  img(src='/static/photos/playlist icon.png' alt='')
                  span Party Songs
                td 19
        #insights.widget
          h4  Insights 
          .items
            .left &#x1F3B5;
            .right
              p
                b Arijit Singh
                |  is your top Artist.
              p You are listening to Arijit Singh the most.
          .items
            .left &#x2B50;
            .right
              p
                b Sapphire
                |  is your top track.
              p You listened this track most this week.
          .items
            .left &#x1F525;
            .right
              p
                b Chill Vibes
                |  tops your playlist rankings.
              p It&apos;s your most-played playlist this week. 
script(src='https://cdn.jsdelivr.net/npm/apexcharts')
script(src='/static/analyticsspotify.js')
