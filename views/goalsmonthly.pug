doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Project01
  link(rel='stylesheet' href='/static/goalsmonthly.css')
.container
  // Sidebar
  aside.sidebar
    .logo
      img(src='/static/photos/dashboard logo.png' alt='')
      h2 Dashboard
    ul.menu
      li
        a(href='/dashboard')
          img(src='/static/photos/overview icon.png' alt='')
          span  Overview 
      li
        a(href='/analyticsgithub')
          img(src='/static/photos/analytics icon.png' alt='')
          span Analytics
      li.active
        a(href='/goals')
          img(src='/static/photos/goals icon.png' alt='')
          span Goals
      li
        a(href='/integration')
          img(src='/static/photos/integrations icon.png' alt='')
          span Integrations
      li
        a(href='/reports')
          img(src='/static/photos/reports icon.png' alt='')
          span Reports
      li
        a(href='/achievements')
          img(src='/static/photos/achievements icon.png' alt='')
          span Achievements
      li
        a(href='/settingsprofile')
          img(src='/static/photos/settings icon.png' alt='')
          span Settings
  // main content
  .main-content
    // responsive header
    header.responsive-header
      .header-left
        button.menu-btn(onclick='roggle()')  &#x2630; 
        h2 Dashboard
      .header-right
        .notification-wrapper
          img.notifications-icon(src='/static/photos/notifications icon.jpeg' alt='notification')
          span.badge 3
        img.profile-logo(src='/static/photos/profile logo.png' alt='profile photo')
    .content(onclick='moggle()')
      // Header
      header.goals-header
        .header-left
          h2 Goals
          p  Set goals, track progress and achieve more 
        .header-right
          button.goal-btn(onclick="window.location.href='/newgoals' ") + New Goal
      // Tabs
      .goal-tabs
        button(onclick="window.location.href='/goals' ") All Goals
        button(onclick="window.location.href='/goalsweekly' ") Weekly Goals
        button.active(onclick="window.location.href='/goalsmonthly' ") Monthly Goals
        button(onclick="window.location.href='/goalscustom' ") Custom Goals
      // Goal Cards
      .goal-card
        .goal-icon &#x1F419;
        .goal-content
          .goal-top
            h3 Make 50 GitHub Commits
            span 42 / 50
          .progress-bar
            .progress(style='width:84%;')
          .goal-bottom
            p Target: May 31, 2025
            span 8 days left
      .goal-card
        .goal-icon &#x1F3B5;
        .goal-content
          .goal-top
            h3 Listen to Music for 15 Hours
            span 12.4 / 15 hrs
          .progress-bar
            .progress(style='width:82%;')
          .goal-bottom
            p Target: May 31, 2025
            span 8 days left
script(src='/static/goalsmonthly.js')
